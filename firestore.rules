rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: get workspace data (used in rules)
    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    // Helper: check if user is a workspace member
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        getWorkspace(workspaceId).memberIds.hasAny([request.auth.uid]);
    }

    // Helper: check user role in workspace
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(workspaceId, role) {
      return isWorkspaceMember(workspaceId) && getUserRole() == role;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own doc
      allow read: if isOwner(userId);
      // Users can write their own doc, but only specific fields
      allow write: if isOwner(userId);
      // Allow reading basic user info for member lists (email, displayName, photoURL)
      allow get: if isAuthenticated();
      // Allow listing users for workspace member lookups
      allow list: if isAuthenticated();
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() &&
        resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if isAuthenticated();
      allow update: if getWorkspace(workspaceId).ownerId == request.auth.uid ||
        hasRole(workspaceId, 'admin');
      allow delete: if getWorkspace(workspaceId).ownerId == request.auth.uid;
    }

    // Workspace invites
    match /workspace_invites/{inviteId} {
      // Anyone can read invites (needed for invite acceptance)
      allow read: if isAuthenticated();
      // Only workspace members/admins/owners can create invites
      allow create: if isAuthenticated() &&
        isWorkspaceMember(request.resource.data.workspaceId);
      // Only the invited user or workspace admin can update
      allow update: if isAuthenticated();
      // Only workspace owner/admin can delete
      allow delete: if isAuthenticated() &&
        (get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(resource.data.workspaceId, 'admin'));
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Time entries
    match /timeEntries/{entryId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId) &&
        resource.data.userId == request.auth.uid;
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Automations
    match /automations/{automationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create, update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Conversations (messages module)
    match /conversations/{conversationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    // Meeting Types
    match /meeting_types/{typeId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    // Documents (Cloudinary metadata)
    match /documents/{documentId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    // Emails
    match /emails/{emailId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isWorkspaceMember(resource.data.workspaceId) ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated();  // Created by app logic
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Email Events (tracking opens/clicks)
    match /email_events/{eventId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if true;  // Public tracking endpoints
    }

    // Calendar Tokens (subcollection under users)
    match /users/{userId}/calendar_tokens/{tokenId} {
      allow read, write: if isOwner(userId);
    }
  }
}
