rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: get workspace data (used in rules)
    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    // Helper: check if user is a workspace member
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        getWorkspace(workspaceId).memberIds.hasAny([request.auth.uid]);
    }

    // Helper: get user document data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check effective workspace role (workspaceRoles map first, fallback to top-level role)
    function getWorkspaceRole(workspaceId) {
      let userData = getUserData();
      let workspaceRoles = userData.workspaceRoles;
      // Check workspaceRoles map first, fallback to top-level role field
      return workspaceRoles != null && workspaceRoles[workspaceId] != null
        ? workspaceRoles[workspaceId]
        : userData.role;
    }

    function hasRole(workspaceId, role) {
      return isWorkspaceMember(workspaceId) && getWorkspaceRole(workspaceId) == role;
    }

    // Helper: check if user can write (owner, admin, or member — not viewer or client)
    function canWrite(workspaceId) {
      return isWorkspaceMember(workspaceId) && (
        getWorkspaceRole(workspaceId) == 'owner' ||
        getWorkspaceRole(workspaceId) == 'admin' ||
        getWorkspaceRole(workspaceId) == 'member'
      );
    }

    // Helper: check if user has client role in this workspace
    function isClient(workspaceId) {
      return isWorkspaceMember(workspaceId) && getWorkspaceRole(workspaceId) == 'client';
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own doc
      allow read: if isOwner(userId);
      // Users can write their own doc, but only specific fields
      allow write: if isOwner(userId);
      // Allow reading basic user info for member lists (email, displayName, photoURL)
      allow get: if isAuthenticated();
      // Allow listing users for workspace member lookups
      allow list: if isAuthenticated();
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() &&
        resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if isAuthenticated();
      allow update: if getWorkspace(workspaceId).ownerId == request.auth.uid ||
        hasRole(workspaceId, 'admin');
      allow delete: if getWorkspace(workspaceId).ownerId == request.auth.uid;
    }

    // Workspace invites
    match /workspace_invites/{inviteId} {
      // Anyone can read invites (needed for invite acceptance)
      allow read: if isAuthenticated();
      // Only workspace members with write access can create invites
      allow create: if canWrite(request.resource.data.workspaceId);
      // Only the invited user or workspace admin can update
      allow update: if isAuthenticated();
      // Only workspace owner/admin can delete
      allow delete: if isAuthenticated() &&
        (get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(resource.data.workspaceId, 'admin'));
    }

    // Client portal settings (per-workspace configuration)
    match /client_portal_settings/{workspaceId} {
      // Workspace members can read (clients included, to see what's enabled)
      allow read: if isWorkspaceMember(workspaceId);
      // Only owner/admin can write
      allow write: if isAuthenticated() &&
        (get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(workspaceId, 'admin'));
    }

    // Spreadsheets (per-workspace subcollection)
    match /workspaces/{workspaceId}/spreadsheets/{spreadsheetId} {
      // Workspace members can read
      allow read: if isWorkspaceMember(workspaceId);
      // Authenticated workspace members can create
      allow create: if isAuthenticated() && isWorkspaceMember(workspaceId) &&
        request.resource.data.workspaceId == workspaceId;
      // Authenticated workspace members can update (cannot change workspaceId)
      allow update: if isAuthenticated() && isWorkspaceMember(workspaceId) &&
        request.resource.data.workspaceId == workspaceId &&
        request.resource.data.snapshot.size() < 1000000;
      // Only owner/admin can delete
      allow delete: if isAuthenticated() &&
        (get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(workspaceId, 'admin'));
    }

    // Client checklist progress (per-user)
    match /client_checklist_progress/{docId} {
      // Allow reads when doc doesn't exist (null resource) or belongs to user
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if false; // Never delete
    }

    // Client invites
    match /client_invites/{inviteId} {
      // Authenticated users can read (for invite verification)
      allow read: if isAuthenticated();
      // Only workspace owner/admin can create
      allow create: if isAuthenticated() &&
        (request.resource.data.role == 'client') &&
        exists(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)) &&
        (get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(request.resource.data.workspaceId, 'admin'));
      // Workspace owner/admin can update (cancel/resend)
      allow update: if isAuthenticated() &&
        (resource.data.workspaceId is string) &&
        (get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(resource.data.workspaceId, 'admin'));
      allow delete: if isAuthenticated() &&
        (resource.data.workspaceId is string) &&
        (get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
         hasRole(resource.data.workspaceId, 'admin'));
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Time entries
    match /timeEntries/{entryId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      // Workspace members + clients can create their own entries
      allow create: if canWrite(request.resource.data.workspaceId) ||
        (isClient(request.resource.data.workspaceId) &&
         request.resource.data.userId == request.auth.uid);
      // Workspace members can update any; clients can update only their own
      allow update: if canWrite(resource.data.workspaceId) ||
        (isClient(resource.data.workspaceId) &&
         resource.data.userId == request.auth.uid);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Automations
    match /automations/{automationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create, update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Conversations (messages module)
    match /conversations/{conversationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      // Workspace members can create; clients can create where they are a participant
      allow create: if canWrite(request.resource.data.workspaceId) ||
        (isClient(request.resource.data.workspaceId) &&
         request.resource.data.participantIds.hasAny([request.auth.uid]));
      allow update: if canWrite(resource.data.workspaceId) ||
        (isClient(resource.data.workspaceId) &&
         resource.data.participantIds.hasAny([request.auth.uid]));
      allow delete: if canWrite(resource.data.workspaceId);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      // Workspace members can create; clients can create where they are the sender
      allow create: if canWrite(request.resource.data.workspaceId) ||
        (isClient(request.resource.data.workspaceId) &&
         request.resource.data.senderId == request.auth.uid);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if canWrite(resource.data.workspaceId);
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if canWrite(resource.data.workspaceId);
    }

    // Meeting Types
    match /meeting_types/{typeId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if canWrite(resource.data.workspaceId);
    }

    // Documents (Cloudinary metadata)
    match /documents/{documentId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if canWrite(resource.data.workspaceId);
    }

    // Emails
    match /emails/{emailId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if canWrite(resource.data.workspaceId) ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated();  // Created by app logic
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Email Events (tracking opens/clicks)
    match /email_events/{eventId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if true;  // Public tracking endpoints
    }

    // ─── Phase 3: Client-facing collections ──────────────────────────────────

    // Projects
    match /projects/{projectId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if canWrite(request.resource.data.workspaceId);
      allow update: if canWrite(resource.data.workspaceId) || (
        isClient(resource.data.workspaceId) &&
        resource.data.clientId == request.auth.uid
      );
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Project Tasks — authorize reads via project membership
    match /project_tasks/{taskId} {
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId != null &&
        isWorkspaceMember(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        );
      allow create: if isAuthenticated() && canWrite(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && canWrite(resource.data.workspaceId);
      allow delete: if isAuthenticated() && canWrite(resource.data.workspaceId);
    }

    // Project Milestones
    match /project_milestones/{milestoneId} {
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId != null &&
        isWorkspaceMember(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        );
      allow create: if isAuthenticated() && canWrite(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && canWrite(resource.data.workspaceId);
      allow delete: if isAuthenticated() && canWrite(resource.data.workspaceId);
    }

    // Project Notes
    match /project_notes/{noteId} {
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId != null &&
        isWorkspaceMember(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        );
      allow create: if isAuthenticated() && canWrite(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && canWrite(resource.data.workspaceId);
      allow delete: if isAuthenticated() && canWrite(resource.data.workspaceId);
    }

    // Project Time Entries
    match /project_time_entries/{entryId} {
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId != null &&
        isWorkspaceMember(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        );
      allow create: if isAuthenticated() && (canWrite(request.resource.data.workspaceId) || isClient(request.resource.data.workspaceId));
      allow update: if isAuthenticated() && canWrite(resource.data.workspaceId);
      allow delete: if isAuthenticated() && canWrite(resource.data.workspaceId);
    }

    // Project Deliverables
    match /project_deliverables/{deliverableId} {
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId != null &&
        isWorkspaceMember(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        );
      // Workspace members (owner/admin/member) can create
      allow create: if isAuthenticated() && canWrite(request.resource.data.workspaceId);
      // Workspace members can update; clients assigned to the project can also update (approve/revision)
      allow update: if isAuthenticated() && (
        canWrite(resource.data.workspaceId) ||
        (isClient(
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.workspaceId
        ) &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clients != null &&
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clients.hasAny([request.auth.uid]))
      );
      allow delete: if isAuthenticated() && canWrite(resource.data.workspaceId);
    }

    // Calendar Tokens (subcollection under users)
    match /users/{userId}/calendar_tokens/{tokenId} {
      allow read, write: if isOwner(userId);
    }
  }
}
